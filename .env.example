# EKRS RAG Service Configuration
# Copy to .env and fill in values

# Shared secret for parser↔RAG auth (must be >=32 chars)
PARSER_TOKEN=change-me-to-a-secure-random-string-32chars

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Redis
REDIS_URL=redis://localhost:6379

# Shared storage (parser writes JSONL here, RAG reads)
SHARED_STORAGE_PATH=/parsed_lib

# Debug mode (enables verbose logging, dev UI)
EKRS_DEBUG=false

# Qdrant collection name
COLLECTION_NAME=rag_documents

# Chunking
MAX_CHUNK_TOKENS=500

# Minimum chunks for recall gate
MIN_RECALL_CHUNKS=1

# Embedding model (bge-small for dev, bge-m3 for production)
EMBEDDING_MODEL=bge-small-en-v1.5

# Ingestion lock timeout (seconds)
INGESTION_LOCK_TIMEOUT=300

# Phase 4: System Integration
LOCK_TTL_SEC=300            # Redis lock TTL in seconds (default 5 min)
MAX_ATTEMPTS=3              # Compensation retry cap per task
TASK_DB_PATH=/var/lib/ekrs/tasks.db   # SQLite path for the tasks table

# Server
HOST=0.0.0.0
PORT=8000

# Phase 5: Observability
AUDIT_LOG_PATH=audit.log            # 永久 audit.log 路径
DEBUG_LOG_PATH=logs/debug.log       # debug 日志路径 (仅 EKRS_DEBUG=true 时生效)

# Phase 5.5 D: Metrics sidecar exporter (与 RAG 主端口 8000 分离)
# PROMETHEUS_MULTIPROC_DIR: 多 worker 模式必填;单 worker 留空即可。
# 必须在 uvicorn fork 子进程前由部署层设置(部署层面的 env)。
# PROMETHEUS_MULTIPROC_DIR=/tmp/prom_multiproc
METRICS_HOST=127.0.0.1  # docker-compose overrides to 0.0.0.0 for cross-container scrape
METRICS_PORT=9090
