+  "status": "OK",  # or "CONFLICT" or "EMPTY"
+  "parameters": {
+    "temperature": {
+      "range": [10.0, 80.0],  # None = -inf, None = +inf
+      "unit": "°C",
+      "confidence": 0.95,
+      "evidence": [...],
+    }
+  },
+  "conflicts": [],  # only when CONFLICT
